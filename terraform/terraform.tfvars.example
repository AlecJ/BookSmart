# Copy this file to terraform.tfvars and fill in values for local Terraform runs.
# In CI, all variables are stored in Terraform Cloud workspace settings.
# Never commit terraform.tfvars — it is gitignored.

# ─── Neon ────────────────────────────────────────────────────────────────────
neon_api_key = "your-neon-api-key"
neon_org_id  = "org-xxxx-xxxx" # console.neon.tech → Organization → Settings

# ─── Render ──────────────────────────────────────────────────────────────────
render_api_key  = "rnd_xxxxxxxxxxxxxxxxxxxx"
render_owner_id = "usr-xxxxxxxxxxxxxxxxxxxx" # or tea-xxxx for a team workspace
render_region   = "oregon"
render_plan     = "starter" # "free" works for learning but spins down after inactivity

# ─── Docker / GHCR ───────────────────────────────────────────────────────────
image_tag  = "latest"
ghcr_token = "ghp_xxxxxxxxxxxxxxxxxxxx" # GitHub PAT with read:packages scope

# ─── App config ──────────────────────────────────────────────────────────────
secret_key     = "replace-with-output-of-openssl-rand-hex-32"
openai_api_key = "sk-xxxxxxxxxxxxxxxxxxxx"
openai_model   = "gpt-4o-mini"
google_api_key = "AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
project_name   = "BookSmart"
frontend_host  = "" # e.g. https://your-frontend.onrender.com
